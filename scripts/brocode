#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_DIR="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
PRIMARY_BINARY="$REPO_DIR/brocode-rs/target/release/brocode"
DEBUG_BINARY="$REPO_DIR/brocode-rs/target/debug/brocode"
FALLBACK_BINARY="/opt/homebrew/bin/brocode"
LEGACY_FALLBACK_BINARY="/opt/homebrew/bin/brocode"
export PATH="/opt/homebrew/bin:/usr/bin:/bin:${PATH:-}"
DEFAULT_BROCODE_HOME="$HOME/.brocode"

if [ -x "$PRIMARY_BINARY" ] && [ -x "$DEBUG_BINARY" ]; then
  if [ "$DEBUG_BINARY" -nt "$PRIMARY_BINARY" ]; then
    BINARY="$DEBUG_BINARY"
  else
    BINARY="$PRIMARY_BINARY"
  fi
elif [ -x "$PRIMARY_BINARY" ]; then
  BINARY="$PRIMARY_BINARY"
elif [ -x "$DEBUG_BINARY" ]; then
  BINARY="$DEBUG_BINARY"
elif [ -x "$FALLBACK_BINARY" ]; then
  BINARY="$FALLBACK_BINARY"
  printf 'brocode: local clone binary not built yet, using %s\n' "$BINARY" >&2
elif [ -x "$LEGACY_FALLBACK_BINARY" ]; then
  BINARY="$LEGACY_FALLBACK_BINARY"
  printf 'brocode: rebranded binary not built yet, using legacy %s\n' "$BINARY" >&2
else
  printf 'brocode binary not available at %s, %s, %s, or %s\n' "$PRIMARY_BINARY" "$DEBUG_BINARY" "$FALLBACK_BINARY" "$LEGACY_FALLBACK_BINARY" >&2
  exit 1
fi

export BROCODE_HOME="${BROCODE_HOME:-$DEFAULT_BROCODE_HOME}"
install -d -m 700 "$BROCODE_HOME"
export CODEX_HOME="$BROCODE_HOME"

# proxy selection:
# - preserve explicit shell proxy env when already set
# - allow explicit opt-in/opt-out with BROCODE_USE_TAILNET_PROXY=1/0
# - otherwise, auto-use the local tailscale proxy when it is listening
proxy_url="${BROCODE_TAILNET_PROXY_URL:-http://127.0.0.1:18888}"
if [ "${BROCODE_USE_TAILNET_PROXY:-}" = "1" ]; then
  export HTTP_PROXY="$proxy_url"
  export HTTPS_PROXY="$proxy_url"
elif [ "${BROCODE_USE_TAILNET_PROXY:-}" = "0" ]; then
  unset HTTP_PROXY HTTPS_PROXY
elif [ -n "${HTTP_PROXY:-}" ] || [ -n "${HTTPS_PROXY:-}" ]; then
  :
elif command -v nc >/dev/null 2>&1 && nc -z 127.0.0.1 18888 >/dev/null 2>&1; then
  export HTTP_PROXY="$proxy_url"
  export HTTPS_PROXY="$proxy_url"
else
  unset HTTP_PROXY HTTPS_PROXY
fi
export NO_PROXY="${NO_PROXY:-localhost,127.0.0.1,::1}"
unset ALL_PROXY

need_yolo=1
for arg in "$@"; do
  if [ "$arg" = "--yolo" ] || [ "$arg" = "--dangerously-bypass-approvals-and-sandbox" ] || [ "$arg" = "--full-auto" ]; then
    need_yolo=0
    break
  fi
done

if [ "$need_yolo" -eq 1 ]; then
  final_args=()
  inserted=0
  for arg in "$@"; do
    if [ "$arg" = "--" ] && [ "$inserted" -eq 0 ]; then
      final_args+=("--yolo")
      inserted=1
    fi
    final_args+=("$arg")
  done
  if [ "$inserted" -eq 0 ]; then
    final_args+=("--yolo")
  fi
  set -- "${final_args[@]}"
fi

exec "$BINARY" "$@"
